<section class="inventory-block">
  <h3>
    {{localize 'ARISTILIA.Inventory.title'}}
    <small>({{grid.cols}} × {{grid.rows}})</small>
    <a class="item-create" data-action="createItem" data-type="gear" title="{{localize 'ARISTILIA.Add'}}"><i class="fas fa-plus"></i></a>
  </h3>
  <p class="hint">{{localize 'ARISTILIA.Inventory.hint'}}</p>

  {{> "systems/aristilia/templates/actor/parts/grid-block.hbs" grid}}

  {{#each containers as |c|}}
    <div class="container-block">
      <h4><i class="fas fa-box-open"></i> {{c.name}} <small>({{c.cols}} × {{c.rows}})</small></h4>
      {{> "systems/aristilia/templates/actor/parts/grid-block.hbs" c}}
    </div>
  {{/each}}

  <div class="inv-toolbar">
    <h4 class="backpack-title">{{localize 'ARISTILIA.Inventory.items'}}</h4>
    <input type="search" class="inv-search" placeholder="{{localize 'ARISTILIA.Inventory.search'}}" />
  </div>
  <div class="inv-search-results" hidden></div>
  <ol class="items-list inventory-list two-col">
    {{#each grid.all as |entry|}}
      <li class="item {{#unless entry.placed}}inv-draggable{{/unless}}" data-item-id="{{entry.item.id}}" {{#unless entry.placed}}draggable="true"{{/unless}}>
        <img class="item-icon" src="{{entry.item.img}}" alt="{{entry.item.name}}" />
        <span class="item-name">{{entry.item.name}}</span>
        {{#if entry.container}}
          <span class="badge"><i class="fas fa-box-open"></i> {{localize 'ARISTILIA.Container.label'}} {{entry.inside}}</span>
        {{else}}
          {{#if entry.placed}}
            <span class="badge placed" title="{{localize 'ARISTILIA.Inventory.placedHint'}}"><i class="fas fa-thumbtack"></i> {{localize 'ARISTILIA.Inventory.placed'}}</span>
          {{else}}
            <span class="item-detail">{{entry.item.system.size.w}}×{{entry.item.system.size.h}}</span>
          {{/if}}
        {{/if}}
        <span class="item-controls">
          {{#if entry.container}}
            <a data-action="toggleEquip" data-item-id="{{entry.item.id}}" class="{{#if entry.item.system.slot.equipped}}on{{/if}}"
               title="{{#if entry.item.system.slot.equipped}}{{localize 'ARISTILIA.Container.store'}}{{else}}{{localize 'ARISTILIA.Container.wear'}}{{/if}}"><i class="fas fa-person-hiking"></i></a>
            <a data-action="viewContainer" data-item-id="{{entry.item.id}}" title="{{localize 'ARISTILIA.Container.view'}}"><i class="fas fa-eye"></i></a>
          {{else}}
            {{#if entry.placed}}
              <a data-action="unplaceItem" data-item-id="{{entry.item.id}}" title="{{localize 'ARISTILIA.Inventory.unplace'}}"><i class="fas fa-arrow-rotate-left"></i></a>
            {{else}}
              <a data-action="placeItem" data-item-id="{{entry.item.id}}" title="{{localize 'ARISTILIA.Inventory.place'}}"><i class="fas fa-table-cells-large"></i></a>
            {{/if}}
          {{/if}}
          <a data-action="editItem" data-item-id="{{entry.item.id}}"><i class="fas fa-edit"></i></a>
          <a data-action="deleteItem" data-item-id="{{entry.item.id}}"><i class="fas fa-trash"></i></a>
        </span>
      </li>
    {{else}}
      <li class="empty">{{localize 'ARISTILIA.Inventory.empty'}}</li>
    {{/each}}
  </ol>
</section>
