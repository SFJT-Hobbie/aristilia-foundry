<div class="aristilia-sheet character">

  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" data-action="editImage" alt="{{actor.name}}" />
    <div class="header-fields">
      <input type="text" name="name" value="{{actor.name}}" placeholder="{{localize 'ARISTILIA.Name'}}" class="charname" />
      <div class="header-row">
        <label>{{localize 'ARISTILIA.Details.race'}}
          <select name="system.details.race">
            {{#each config.races as |label key|}}
              <option value="{{key}}" {{#if (eq key ../system.details.race)}}selected{{/if}}>{{localize label}}</option>
            {{/each}}
          </select>
        </label>
        <label>{{localize 'ARISTILIA.Details.class'}}
          <select name="system.details.class">
            {{#each config.classes as |label key|}}
              <option value="{{key}}" {{#if (eq key ../system.details.class)}}selected{{/if}}>{{localize label}}</option>
            {{/each}}
          </select>
        </label>
        <label>{{localize 'ARISTILIA.Details.alignment'}}
          <select name="system.details.alignment">
            {{#each config.alignments as |label key|}}
              <option value="{{key}}" {{#if (eq key ../system.details.alignment)}}selected{{/if}}>{{localize label}}</option>
            {{/each}}
          </select>
        </label>
      </div>
      <div class="header-row">
        <label>{{localize 'ARISTILIA.Details.level'}} <input type="number" name="system.details.level" value="{{system.details.level}}" /></label>
        <label>{{localize 'ARISTILIA.Details.xp'}} <input type="number" name="system.details.xp" value="{{system.details.xp}}" /></label>
        <label class="derived">{{localize 'ARISTILIA.Details.xpBonus'}} <b>{{system.details.xpBonus}}%</b></label>
        <label>{{localize 'ARISTILIA.Details.rollMethod'}}
          <select name="system.details.rollMethod">
            {{#each config.rollMethods as |label key|}}
              <option value="{{key}}" {{#if (eq key ../system.details.rollMethod)}}selected{{/if}}>{{localize label}}</option>
            {{/each}}
          </select>
        </label>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs">
    <a class="tab-link {{#if (eq activeTab 'main')}}active{{/if}}" data-action="switchTab" data-tab="main"><i class="fas fa-shield-halved"></i> {{localize 'ARISTILIA.Tab.main'}}</a>
    <a class="tab-link {{#if (eq activeTab 'inventory')}}active{{/if}}" data-action="switchTab" data-tab="inventory"><i class="fas fa-box-open"></i> {{localize 'ARISTILIA.Tab.inventory'}}</a>
    <a class="tab-link {{#if (eq activeTab 'skills')}}active{{/if}}" data-action="switchTab" data-tab="skills"><i class="fas fa-scroll"></i> {{localize 'ARISTILIA.Tab.skills'}}</a>
    <a class="tab-link {{#if (eq activeTab 'spells')}}active{{/if}}" data-action="switchTab" data-tab="spells"><i class="fas fa-hat-wizard"></i> {{localize 'ARISTILIA.Tab.spells'}}</a>
    <a class="tab-link {{#if (eq activeTab 'bio')}}active{{/if}}" data-action="switchTab" data-tab="bio"><i class="fas fa-feather"></i> {{localize 'ARISTILIA.Tab.bio'}}</a>
  </nav>

  {{#if (eq activeTab 'main')}}
  <div class="tab-content" data-tab="main">
    {{> "systems/aristilia/templates/actor/parts/attributes.hbs"}}

    <div class="situational-toggle">
      <label>
        <input type="checkbox" data-action="toggleSituational" {{#if situational}}checked{{/if}} />
        {{localize 'ARISTILIA.Situational.toggle'}}
      </label>
      <span class="hint">{{localize 'ARISTILIA.Situational.toggleHint'}}</span>
    </div>

    <section class="combat-block">
      <div class="stat">
        <label>{{localize 'ARISTILIA.HP'}}</label>
        <input type="number" name="system.hp.value" value="{{system.hp.value}}" /> /
        <input type="number" name="system.hp.max" value="{{system.hp.max}}" />
      </div>
      <div class="stat">
        <label>{{localize 'ARISTILIA.AC'}}</label>
        <span class="ac-total" title="{{localize 'ARISTILIA.ACTotal'}}">{{system.ac.value}}</span>
        {{#if system.ac.equipped}}
          <small class="ac-equipped">
            {{#if system.ac.equippedArmor}}{{system.ac.equippedArmor}}{{/if}}
            {{#if system.ac.equippedShield}}{{#if system.ac.equippedArmor}} + {{/if}}{{system.ac.equippedShield}}{{/if}}
          </small>
        {{else}}
          <small>({{localize 'ARISTILIA.ACArmor'}} <input type="number" name="system.ac.armor" value="{{system.ac.armor}}" />
           + {{localize 'ARISTILIA.ACShield'}} <input type="number" name="system.ac.shield" value="{{system.ac.shield}}" />)</small>
        {{/if}}
      </div>
      <div class="stat rollable-stat">
        <a class="stat-roll" data-action="rollHit" title="{{localize 'ARISTILIA.Roll.hit'}}"><i class="fas fa-dice-d20"></i></a>
        <label>{{localize 'ARISTILIA.BonusToHit'}}</label>
        <input type="number" name="system.combat.bonusToHit" value="{{system.combat.bonusToHit}}" title="{{localize 'ARISTILIA.BonusToHit'}}" />
        <label class="sub">{{localize 'ARISTILIA.TargetAC'}}</label>
        <input type="number" name="system.combat.targetAC" value="{{system.combat.targetAC}}" title="{{localize 'ARISTILIA.TargetAC'}}" />
      </div>
      <div class="stat rollable-stat">
        <a class="stat-roll" data-action="rollSave" title="{{localize 'ARISTILIA.Roll.save'}}"><i class="fas fa-dice-d20"></i></a>
        <label>{{localize 'ARISTILIA.BonusToSave'}}</label>
        <input type="number" name="system.combat.bonusToSave" value="{{system.combat.bonusToSave}}" />
      </div>
      <div class="stat"><label>{{localize 'ARISTILIA.MoveClose'}}</label> <b>{{system.movement.close}} ft</b></div>
      <div class="stat"><label>{{localize 'ARISTILIA.MoveOpen'}}</label> <b>{{system.movement.open}} ft</b></div>
      <div class="stat"><label>{{localize 'ARISTILIA.MagicResistance'}}</label> <b>{{system.magicResistance}}%</b></div>
    </section>

    <section class="weapons-block">
      <h3>{{localize 'ARISTILIA.Weapons'}}
        <a class="item-create" data-action="createItem" data-type="weapon" title="{{localize 'ARISTILIA.Add'}}"><i class="fas fa-plus"></i></a>
      </h3>
      <ol class="items-list">
        {{#each items.weapons as |item|}}
          <li class="item" data-item-id="{{item.id}}">
            <img class="item-icon" src="{{item.img}}" alt="{{item.name}}" />
            <span class="item-name">{{item.name}}</span>
            <span class="item-detail">{{item.system.damage}}</span>
            <span class="item-controls">
              <a data-action="rollWeapon" data-item-id="{{item.id}}" title="{{localize 'ARISTILIA.Roll.attack'}}"><i class="fas fa-dice-d20"></i></a>
              <a data-action="editItem" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
              <a data-action="deleteItem" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
            </span>
          </li>
        {{else}}
          <li class="empty">{{localize 'ARISTILIA.NoneYet'}}</li>
        {{/each}}
      </ol>
    </section>

    <section class="armor-block">
      <h3>{{localize 'ARISTILIA.Armor'}}
        <span class="add-group">
          <a class="item-create" data-action="createItem" data-type="armor" title="{{localize 'ARISTILIA.AddArmor'}}"><i class="fas fa-plus"></i> {{localize 'TYPES.Item.armor'}}</a>
          <a class="item-create" data-action="createItem" data-type="shield" title="{{localize 'ARISTILIA.AddShield'}}"><i class="fas fa-plus"></i> {{localize 'TYPES.Item.shield'}}</a>
        </span>
      </h3>
      <ol class="items-list">
        {{#each items.armor as |item|}}
          <li class="item {{#if item.system.slot.equipped}}equipped{{/if}}" data-item-id="{{item.id}}">
            <img class="item-icon" src="{{item.img}}" alt="{{item.name}}" />
            <span class="item-name">{{item.name}}</span>
            <span class="item-detail">{{localize (aristiliaConcat 'TYPES.Item.' item.type)}} · {{localize 'ARISTILIA.AC'}} {{item.system.ac}}</span>
            <span class="item-controls">
              <a data-action="toggleEquip" data-item-id="{{item.id}}" class="{{#if item.system.slot.equipped}}on{{/if}}"
                 title="{{#if item.system.slot.equipped}}{{localize 'ARISTILIA.Unequip'}}{{else}}{{localize 'ARISTILIA.Equip'}}{{/if}}"><i class="fas fa-shield-alt"></i></a>
              <a data-action="editItem" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
              <a data-action="deleteItem" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
            </span>
          </li>
        {{else}}
          <li class="empty">{{localize 'ARISTILIA.NoneYet'}}</li>
        {{/each}}
      </ol>
    </section>
  </div>
  {{/if}}

  {{#if (eq activeTab 'inventory')}}
  <div class="tab-content" data-tab="inventory">
    <section class="resources-block">
      <div class="currency">
        <span class="cur-label">{{localize 'ARISTILIA.Currency.title'}}</span>
        <label>{{localize 'ARISTILIA.Currency.gold'}} <input type="number" name="system.currency.gold" value="{{system.currency.gold}}" min="0" /></label>
        <label>{{localize 'ARISTILIA.Currency.silver'}} <input type="number" name="system.currency.silver" value="{{system.currency.silver}}" min="0" /></label>
        <label>{{localize 'ARISTILIA.Currency.copper'}} <input type="number" name="system.currency.copper" value="{{system.currency.copper}}" min="0" /></label>
      </div>
    </section>
    {{> "systems/aristilia/templates/actor/parts/inventory-grid.hbs"}}
  </div>
  {{/if}}

  {{#if (eq activeTab 'skills')}}
  <div class="tab-content" data-tab="skills">
    <section class="resources-block">
      <label class="languages">{{localize 'ARISTILIA.Languages'}}
        <input type="text" name="system.languages" value="{{system.languages}}" placeholder="Común, Élfico…" />
      </label>
    </section>
    {{> "systems/aristilia/templates/actor/parts/proficiencies.hbs"}}
  </div>
  {{/if}}

  {{#if (eq activeTab 'spells')}}
  <div class="tab-content" data-tab="spells">
    <section class="spells-block">
      <h3>{{localize 'ARISTILIA.Spells'}}
        <a class="item-create" data-action="pickSpell" title="{{localize 'ARISTILIA.Spell.pick'}}"><i class="fas fa-plus"></i></a>
      </h3>
      <ol class="items-list">
        {{#each items.spells as |item|}}
          <li class="item" data-item-id="{{item.id}}">
            <img class="item-icon" src="{{item.img}}" alt="{{item.name}}" />
            <span class="item-name">{{item.name}}</span>
            <span class="item-detail">{{localize (lookup ../config.spellSchools item.system.school)}}{{#if item.system.branch}} · {{item.system.branch}}{{/if}} · {{localize 'ARISTILIA.Spell.level'}} {{item.system.level}}</span>
            <span class="item-controls">
              <a data-action="toChat" data-item-id="{{item.id}}"><i class="fas fa-comment"></i></a>
              <a data-action="editItem" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
              <a data-action="deleteItem" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
            </span>
          </li>
        {{else}}
          <li class="empty">{{localize 'ARISTILIA.NoneYet'}}</li>
        {{/each}}
      </ol>
    </section>
  </div>
  {{/if}}

  {{#if (eq activeTab 'bio')}}
  <div class="tab-content" data-tab="bio">
    <section class="biography">
      <h3>{{localize 'ARISTILIA.Biography'}}</h3>
      {{#if editable}}
        <prose-mirror name="system.biography" value="{{system.biography}}" document-uuid="{{actor.uuid}}"></prose-mirror>
      {{else}}
        <div class="editor-readonly">{{{enrichedBio}}}</div>
      {{/if}}
    </section>
  </div>
  {{/if}}

</div>
